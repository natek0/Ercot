# ERCOT API credentials — copy this file to ".env" and fill in your values.
# The .env file is gitignored and must never be committed.
# Step 0 uses only the PUBLIC key; the ESR key is for later steps.

ERCOT_API_USERNAME=
ERCOT_API_PASSWORD=
ERCOT_PUBLIC_API_SUBSCRIPTION_KEY=
ERCOT_ESR_API_SUBSCRIPTION_KEY=
